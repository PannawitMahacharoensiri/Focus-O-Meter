        "type": "function",
        "z": "6fd4246c520ec427",
        "name": "function 5",
        "func": "const classroom = flow.get('classroom');\n\nlet result = msg.payload.find(el => el.classroom === classroom);\n\nmsg.payload = result || { \"classroom\": flow.get('classroom'), \"incount\": 0, \"outcount\": 0, \"total\": 0 };\n\nreturn msg;",
