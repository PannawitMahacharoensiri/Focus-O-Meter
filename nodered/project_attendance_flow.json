        "id": "ecf47194fbdbb335",
        "type": "function",
        "z": "6fd4246c520ec427",
        "name": "function 3",
        "func": "const data = msg.payload;\nconst classroom = flow.get('classroom');\n\n// Convert timestamp format (ISO → SQL)\nconst ts = data.timestamp.replace(\"T\", \" \");\n\n// SQL query\nmsg.topic = `\nINSERT INTO project_inclass_attendance (classroom ,direction, timestamp)\nVALUES (?, ?, ?)\n`;\n\n// Values\nmsg.payload = [\n    classroom,\n    data.direction,\n    ts\n];\n\nreturn msg;",
