    {
        "id": "d024f28d39935c89",
        "type": "function",
        "z": "6fd4246c520ec427",
        "name": "function 4",
        "func": "msg.topic = `\nSELECT\n  classroom,\n  SUM(CASE WHEN direction = 'IN' THEN 1 ELSE 0 END)  AS incount,\n  SUM(CASE WHEN direction = 'OUT' THEN 1 ELSE 0 END) AS outcount,\n  SUM(CASE WHEN direction = 'IN' THEN 1 ELSE 0 END) -\n  SUM(CASE WHEN direction = 'OUT' THEN 1 ELSE 0 END) AS total\nFROM project_inclass_attendance\nGROUP BY classroom;\n`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 320,
