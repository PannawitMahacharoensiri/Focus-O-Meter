    {
        "id": "362f4a7163b32d1c",
        "type": "function",
        "z": "8c5a428a12cccc62",
        "name": "Transform time",
        "func": "let isoTime = msg.payload;\n\n// convert to Date object\nlet date = new Date(isoTime);\n\n// convert to Thailand time (UTC+7)\nlet thTime = new Date(date.getTime());\n\n// format manually\nlet year = thTime.getFullYear();\nlet month = String(thTime.getMonth() + 1).padStart(2, '0');\nlet day = String(thTime.getDate()).padStart(2, '0');\n\nlet hours = String(thTime.getHours()).padStart(2, '0');\nlet minutes = String(thTime.getMinutes()).padStart(2, '0');\nlet seconds = String(thTime.getSeconds()).padStart(2, '0');\n\nmsg.payload = `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
