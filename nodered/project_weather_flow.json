    {
        "id": "b4349fae6036bf12",
        "type": "function",
        "z": "8c5a428a12cccc62",
        "name": "create payload",
        "func": "const classroom = flow.get('classroom');\n\n// get current server time\nconst now = new Date();\n\n// format to ISO string (like your original)\nconst timestamp =\n    now.getFullYear() + \"-\" +\n    String(now.getMonth() + 1).padStart(2, '0') + \"-\" +\n    String(now.getDate()).padStart(2, '0') + \" \" +   \n    String(now.getHours()).padStart(2, '0') + \":\" +\n    String(now.getMinutes()).padStart(2, '0') + \":\" +\n    String(now.getSeconds()).padStart(2, '0');\n\nmsg.topic = `\nINSERT INTO inclass_weather\n(temp_c, light_l, humid_p, sound_ADC, measureTime, class)\nVALUES (?, ?, ?, ?, ?, ?)\n`;\n\nmsg.payload = [\n    msg.payload.temp_c,\n    msg.payload.light_l,\n    msg.payload.humid_p,\n    msg.payload.sound_ADC,\n    timestamp,\n    classroom,\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 680,
        "y": 60,
        "wires": [
