    {
        "id": "54969ce6502a6bca",
        "type": "function",
        "z": "8c5a428a12cccc62",
        "name": "Aggregration",
        "func": "msg.topic = `\nSELECT\nAVG(temp_c) AS avg_temp,\nMIN(temp_c) AS min_temp,\nMAX(temp_c) AS max_temp,\n\nAVG(light_l) AS avg_light,\nMIN(light_l) AS min_light,\nMAX(light_l) AS max_light,\n\nAVG(humid_p) AS avg_humid,\nMIN(humid_p) AS min_humid,\nMAX(humid_p) AS max_humid,\n\nAVG(sound_ADC) AS avg_sound,\nMIN(sound_ADC) AS min_sound,\nMAX(sound_ADC) AS max_sound\n\nFROM inclass_weather\nWHERE timestamp >= NOW() - INTERVAL 1 HOUR;\n`;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 720,
        "wires": [
